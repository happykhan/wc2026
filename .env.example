# football-data.org free-tier API key
# Sign up at https://www.football-data.org/client/register
#
# Set FOOTBALL_DATA_KEY in Vercel project settings as a server-side env var.
# The key is read by the /api/scores and /api/standings serverless proxy
# functions — it is never bundled into client-side JavaScript.
#
# For local development with the Vercel CLI:
#   vercel env pull .env.local
# or create .env.local manually with:
#   FOOTBALL_DATA_KEY=your_key_here
# Then run: vercel dev  (not `vite dev` — the proxy functions need the runtime)
FOOTBALL_DATA_KEY=your_key_here
