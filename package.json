{
  "name": "wc2026",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "FIFA World Cup 2026 schedule, live scores, lineups & stats, and per-country TV guide — in your timezone and language. No paid APIs.",
  "homepage": "https://worldcup.happykhan.com",
  "repository": { "type": "git", "url": "https://github.com/happykhan/wc2026.git" },
  "bugs": { "url": "https://github.com/happykhan/wc2026/issues" },
  "license": "MIT",
  "author": "Nabil-Fareed Alikhan",
  "keywords": ["world-cup", "world-cup-2026", "football", "soccer", "live-scores", "fixtures", "react", "vite"],
  "scripts": {
    "dev": "vite",
    "build": "node scripts/gen-match-index.mjs && vitest run && tsc -b && tsc -p tsconfig.api.json --noEmit && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "fetch-fixtures": "node scripts/fetch-fixtures.mjs",
    "fetch-afl-fixtures": "node scripts/fetch-afl-fixtures.mjs",
    "fetch-afl-teams": "node scripts/fetch-afl-teams.mjs",
    "test": "vitest run",
    "test:cache": "node scripts/test-cache.mjs"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/og": "^0.6.8",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "ical-generator": "^11.0.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.8.12",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  }
}
